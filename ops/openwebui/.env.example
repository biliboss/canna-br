# canna-oss Open WebUI deploy — environment template
#
# Copy to `.env` and fill secrets. NEVER commit `.env`.
# Generate strong values with the commands below.

# ============================================================
# Postgres (OWUI metadata store)
# ============================================================
# Generate: openssl rand -base64 32
DB_PASSWORD=replace-with-openssl-rand-base64-32

# ============================================================
# Open WebUI session/crypto key
# ============================================================
# Generate: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
WEBUI_SECRET_KEY=replace-with-secrets-token-urlsafe-32

# ============================================================
# OAuth (Authentik) — defer until SSO is wired in v0.2.1.x
# ============================================================
# Once Authentik provider is created:
#   1. Register OWUI as OIDC client
#   2. Map groups -> OWUI roles (admin / user)
#   3. Set OAUTH_PROVIDERS=authentik in docker-compose.yml
#   4. Uncomment OAUTH_* in compose env block
#OAUTH_CLIENT_ID=
#OAUTH_CLIENT_SECRET=
#OAUTH_ISSUER=https://auth.fonsecagabriel.com.br/application/o/canna-owui

# ============================================================
# Optional: LLM provider keys (set in OWUI admin UI preferably)
# ============================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ============================================================
# Reverse proxy host (for Caddy/Traefik label resolution)
# ============================================================
# WEBUI_HOSTNAME=webui.canna.fonsecagabriel.com.br
