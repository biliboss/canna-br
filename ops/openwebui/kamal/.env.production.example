# canna-oss — Kamal v2 production secrets (template)
#
# DO NOT commit the resolved .env.production. Per _memory/feedback-langfuse-fonsecagabriel-skill.md
# canonical pattern is envless or Bitwarden — fetch at deploy time.
#
# Generate values:
#   openssl rand -hex 32                                          # *_SECRET, *_KEK_SEED
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))" # WEBUI_SECRET_KEY
#   openssl rand -base64 24 | tr -d '+/='                         # passwords (alphanum-only avoids URL-encode issues)
#
# Composite URLs: URL-encode passwords with special chars (/+=) — see gotcha #7.

# === Postgres (shared instance, two DBs: canna + openwebui) ===
POSTGRES_PASSWORD=__FILL__
DATABASE_URL=postgresql://canna:__POSTGRES_PASSWORD__@canna-postgres:5432/canna
WEBUI_DATABASE_URL=postgresql://canna:__POSTGRES_PASSWORD__@canna-postgres:5432/openwebui

# === Redis (shared, separate logical DBs) ===
REDIS_URL=redis://canna-redis:6379/0
WEBUI_REDIS_URL=redis://canna-redis:6379/1

# === Open WebUI ===
WEBUI_SECRET_KEY=__FILL__
ADMIN_EMAIL=admin@canna.fonsecagabriel.com.br
ADMIN_PASSWORD=__FILL__

# === canna-api / mcp / worker ===
JWT_SECRET=__FILL__
SITE_KEK_SEED=__FILL__

# === Observability — reuses langfuse.fonsecagabriel.com.br ===
# Fetch via: bun ~/.obsidian/99-development/langfuse/skill/langfuse-fonsecagabriel/scripts/onboard.ts
LANGFUSE_PUBLIC_KEY=__FILL__
LANGFUSE_SECRET_KEY=__FILL__
LANGFUSE_HOST=https://langfuse.fonsecagabriel.com.br

# === Kamal registry (localhost:5555 trick — never used but Kamal requires non-empty) ===
KAMAL_REGISTRY_PASSWORD=unused
