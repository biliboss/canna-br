# canna-br — v0.1.0 self-host environment.
#
#   cp .env.example .env   then fill the values below and `docker compose up`.
#
# NO REAL SECRETS in this file. Replace every CHANGE_ME before going live.

# --- Postgres (event store + read models) -------------------------------
# Used to build DATABASE_URL inside compose. Pick a strong password.
POSTGRES_DB=canna
POSTGRES_USER=canna
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# DATABASE_URL is assembled by docker-compose from the POSTGRES_* vars above
# (postgres://canna:***@postgres:5432/canna). Override here only if you point
# the apps at an external/managed Postgres (e.g. Neon) instead of the bundled
# service:
# DATABASE_URL=postgres://user:pass@host:5432/canna

# --- Zitadel (auth / multi-tenant, self-host) ---------------------------
# Masterkey MUST be exactly 32 bytes. Generate one:
#   openssl rand -base64 24 | head -c 32 ; echo
ZITADEL_MASTERKEY=CHANGE_ME_exactly_32_bytes______
ZITADEL_EXTERNALDOMAIN=localhost
ZITADEL_EXTERNALPORT=8080
ZITADEL_EXTERNALSECURE=false
ZITADEL_DB=zitadel

# --- MCP <-> agent wiring ------------------------------------------------
MCP_ENABLED=true
# Internal compose DNS name of the mcp service. From the host use http://localhost:3001
MCP_SERVER_URL=http://mcp:3001

# v0.2.1 stub identity headers consumed by apps/mcp (x-canna-*). Real OAuth 2.1
# via Zitadel is a TODO — until then the MCP server trusts these.
CANNA_USER=admin
CANNA_ROLE=admin
CANNA_ASSOCIATION=default

# --- Agent (only needed with `docker compose --profile agent up`) -------
# OpenRouter key for the chat assistant. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=CHANGE_ME_openrouter_key
MODEL_ID=google/gemini-2.5-flash-lite
NEXT_PUBLIC_DOCS_URL=http://localhost:4337

# --- API tunables (optional) --------------------------------------------
LOG_LEVEL=info
# Comma-separated origins, or leave empty for same-origin only.
CORS_ORIGIN=
