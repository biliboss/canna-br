{
  "name": "canna-oss",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OSS cannabis association management system — RDC 1.014 sandbox BR. Domain-first, event-sourced, agentic-native, self-hosted.",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "pnpm --filter @canna/docs dev",
    "build": "pnpm -r build",
    "preview": "pnpm --filter @canna/docs preview",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:domain": "pnpm --filter @canna/domain test",
    "test:watch": "pnpm --filter @canna/domain test:watch",
    "coverage": "pnpm --filter @canna/domain coverage",
    "coverage:report": "node scripts/coverage-report.mjs",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "verify": "pnpm typecheck && pnpm test",
    "validate:typecheck": "pnpm --filter @canna/shared --filter @canna/domain --filter @canna/event-store --filter @canna/read-models --filter @canna/crypto --filter @canna/sngpc --filter @canna/app-services --filter @canna/ui-apps --filter @canna/mcp --filter @canna/api --filter @canna/worker --filter @canna/test-utils --if-present typecheck",
    "validate": "pnpm validate:typecheck && pnpm test && pnpm --filter @canna/ui-apps build && node scripts/validate-mcp-health.mjs",
    "test:e2e:prod": "playwright test",
    "test:e2e:prod:list": "playwright test --list",
    "gates:install": "lefthook install",
    "gates:verify": "node scripts/assert-gates.mjs"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.61.0",
    "lefthook": "^2.1.9",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.11",
    "pnpm": ">=10"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "22.19.20"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
