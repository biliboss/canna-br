        background: oklch(0.72 0.17 162);
        border-color: oklch(0.72 0.17 162);
        transform: scale(1.3);
      }

      .dot:focus-visible {
        outline: 2px solid oklch(0.72 0.17 162);
        outline-offset: 3px;
      }

      /* ── Reduced motion ── */
      @media (prefers-reduced-motion: reduce) {
        .carousel-track {
          scroll-behavior: auto !important;
        }
        .dot,
        .carousel-arrow {
          transition-duration: 0.01ms !important;
        }
      }
    </style>

    <script is:inline>
    (function () {
      var track    = document.getElementById('convites-track');
      var dotsWrap = document.getElementById('convites-dots');
      var prevBtn  = document.querySelector('.carousel-prev');
      var nextBtn  = document.querySelector('.carousel-next');
      if (!track || !dotsWrap) return;

      var dots  = Array.from(dotsWrap.querySelectorAll('.dot'));
      var cards = Array.from(track.querySelectorAll('.snap-card'));
      var total = cards.length;

      /* ── card width (including gap) ── */
      function cardStep() {
        if (cards.length < 2) return track.scrollWidth;
        var r0 = cards[0].getBoundingClientRect();
        var r1 = cards[1].getBoundingClientRect();
        return r1.left - r0.left;
      }

      /* ── scroll to card index ── */
      function scrollTo(idx) {
        var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        track.scrollBy({
          left: (idx - activeIndex()) * cardStep(),
          behavior: reduced ? 'auto' : 'smooth',
        });
      }

      /* ── detect which card is most visible ── */
      function activeIndex() {
        var mid = track.getBoundingClientRect().left + track.getBoundingClientRect().width / 2;
        var best = 0, bestDist = Infinity;
        cards.forEach(function (c, i) {
          var cr = c.getBoundingClientRect();
          var center = cr.left + cr.width / 2;
          var dist = Math.abs(center - mid);
          if (dist < bestDist) { bestDist = dist; best = i; }
        });
        return best;
      }

      /* ── sync dots + arrows ── */
      function syncUI(idx) {
        dots.forEach(function (d, i) {
          var active = i === idx;
          d.classList.toggle('dot-active', active);
          d.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        if (prevBtn) prevBtn.disabled = idx === 0;
        if (nextBtn) nextBtn.disabled = idx === total - 1;
      }

      /* ── IntersectionObserver — sync on scroll ── */
      var obs = new IntersectionObserver(function () {
        syncUI(activeIndex());
      }, { root: track, threshold: 0.5 });
      cards.forEach(function (c) { obs.observe(c); });

      /* ── Arrow clicks ── */
      [prevBtn, nextBtn].forEach(function (btn) {
        if (!btn) return;
        btn.addEventListener('click', function () {
          var dir = parseInt(btn.getAttribute('data-dir'), 10);
          scrollTo(activeIndex() + dir);
        });
      });

      /* ── Dot clicks ── */
      dots.forEach(function (d) {
        d.addEventListener('click', function () {
          scrollTo(parseInt(d.getAttribute('data-i'), 10));
        });
      });

      /* ── Keyboard nav on track ── */
      track.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowRight') { e.preventDefault(); scrollTo(Math.min(activeIndex() + 1, total - 1)); }
        if (e.key === 'ArrowLeft')  { e.preventDefault(); scrollTo(Math.max(activeIndex() - 1, 0)); }
      });

      /* ── init ── */
      syncUI(0);
    })();
    </script>

  </section>
