---
/**
 * /transparencia/ — Transparência pública do canna-br.
 *
 * Secoes:
 *   1. Por que transparência — tese OSS + observabilidade pública.
 *   2. Estado da rede (StateSnapshot widget).
 *   3. Roadmap — resumo v0.x + link canonical.
 *   4. Changelog & releases recentes.
 *   5. ADRs — decisões arquiteturais públicas.
 *   6. Visão OSS — AGPL, self-host, auditabilidade.
 *   7. Status do sistema — honesto: pré-piloto.
 *
 * MarketingLayout contract. Carimbo em destaque.
 * ZERO linguagem de investimento/rendimento/retorno financeiro.
 */

import MarketingLayout from '../components/marketing/MarketingLayout.astro';
import StateSnapshot from '../components/marketing/widgets/StateSnapshot.astro';
import ReleasesDashboard from '../components/marketing/widgets/ReleasesDashboard.astro';
import CostLedger from '../components/marketing/widgets/CostLedger.astro';
---

<MarketingLayout
  title="Transparência — canna-br"
  description="Roadmap público, changelog, releases, decisões de arquitetura (ADRs) e estado da rede do canna-br. Software aberto, evolução pública e indicadores visíveis."
  canonical="https://canna-br.fonsecagabriel.com.br/transparencia/"
>

  <!-- ============================================================
       HERO
  ============================================================ -->
  <section class="transp-hero">
    <div class="transp-container">
      <p class="transp-eyebrow">Transparência</p>
      <h1 class="transp-h1">
        Tudo aberto:<br class="hide-mobile" />
        código, roadmap, decisões, estado atual.
      </h1>
      <p class="transp-lead">
        Não pedimos confiança sem evidências. O canna-br não tem investidores,
        não tem métricas de crescimento para esconder, e não tem código proprietário
        trancado em servidor privado. Tudo que existe — código, roadmap, decisões,
        releases, estado atual — está documentado aqui e atualizável por qualquer pessoa.
      </p>
      <div class="transp-hero-badges">
        <span class="transp-badge transp-badge--ok">
          <span aria-hidden="true">●</span>
          AGPL-3.0 — código aberto
        </span>
        <span class="transp-badge transp-badge--info">
          <span aria-hidden="true">◐</span>
          Pré-piloto — 0 associações em operação
        </span>
        <span class="transp-badge transp-badge--plan">
          <span aria-hidden="true">○</span>
          v0.1.0 · fundação usável · 154/154 testes verdes
        </span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       POR QUE TRANSPARÊNCIA
  ============================================================ -->
  <section class="transp-section transp-section--alt">
    <div class="transp-container">
      <h2 class="transp-h2">Por que transparência — e não apenas código aberto?</h2>
      <div class="transp-why-grid">
        <div class="transp-why-card">
          <div class="transp-why-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h3 class="transp-why-title">Código auditável</h3>
          <p class="transp-why-text">
            Qualquer pessoa — advogada, diretora, fiscal — pode ler cada linha que
            processa dados de saúde dos membros. AGPL-3.0: fork permitido, sem lock-in.
          </p>
        </div>
        <div class="transp-why-card">
          <div class="transp-why-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
            </svg>
          </div>
          <h3 class="transp-why-title">Evolução declarada</h3>
          <p class="transp-why-text">
            Roadmap, releases e ADRs são documentos vivos. O que está pronto,
            o que está planejado e por que decisões foram tomadas — tudo público.
          </p>
        </div>
        <div class="transp-why-card">
          <div class="transp-why-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3 class="transp-why-title">Estado honesto — inclusive o que falta</h3>
          <p class="transp-why-text">
            Pilotos ativos: 0. SNGPC: mock, aguardando XSD da ANVISA.
            O carimbo de atualização mostra quando os dados foram gerados.
            Dizer o que ainda não existe é parte do que construímos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       ESTADO DA REDE (StateSnapshot widget)
  ============================================================ -->
  <section class="transp-section" id="estado-da-rede" aria-labelledby="estado-heading">
    <div class="transp-container">
      <p class="transp-eyebrow-sm">Indicadores públicos</p>
      <h2 class="transp-h2" id="estado-heading">Estado da rede</h2>
      <p class="transp-section-lead">
        Indicadores gerados a partir do repositório e do roadmap — à vista,
        com carimbo de quando foram atualizados. Quando o sistema entrar em operação,
        este snapshot será substituído por leitura em tempo real, sem mudar a interface.
      </p>
      <StateSnapshot />
    </div>
  </section>

  <!-- ============================================================
       ROADMAP
  ============================================================ -->
  <section class="transp-section transp-section--alt" id="roadmap" aria-labelledby="roadmap-heading">
    <div class="transp-container">
      <p class="transp-eyebrow-sm">Roadmap público</p>
      <h2 class="transp-h2" id="roadmap-heading">O que está sendo construído</h2>
      <p class="transp-section-lead">
        Versões declaradas por Slice Vertical — cada entrega tem capability, valor e critério
        de conclusão. Sem semanas; sem promessas vagas.
      </p>

      <div class="transp-widget-wrap">
        <ReleasesDashboard view="roadmap" />
      </div>

      <div class="transp-roadmap-link">
        <a href="/roadmap/" class="transp-btn-outline">
          Ver roadmap completo com todos os Slices Verticais →
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CHANGELOG & RELEASES
  ============================================================ -->
  <section class="transp-section" id="releases" aria-labelledby="releases-heading">
    <div class="transp-container">
      <p class="transp-eyebrow-sm">Changelog & Releases</p>
      <h2 class="transp-h2" id="releases-heading">Histórico de entregas</h2>
      <p class="transp-section-lead">
        Cada release é documentada com o que mudou, por que mudou e o estado dos testes.
        Sem marketing retroativo — o que está escrito é o que foi entregue.
      </p>

      <div class="transp-widget-wrap">
        <ReleasesDashboard view="changelog" />
      </div>
    </div>
  </section>

  <!-- ============================================================
       CUSTOS & QUEM PAGOU
  ============================================================ -->
  <section class="transp-section transp-section--alt" id="custos" aria-labelledby="custos-heading">
    <div class="transp-container">
      <p class="transp-eyebrow-sm">Custos &amp; quem pagou</p>
      <h2 class="transp-h2" id="custos-heading">Sem investidores — cada custo à vista</h2>
      <p class="transp-section-lead">
        Sem investidores e sem receita ainda — cada custo do projeto e quem o pagou ficam
        registrados aqui. Transparência também sobre o dinheiro.
      </p>
      <div class="transp-widget-wrap">
        <CostLedger />
      </div>
    </div>
  </section>

  <!-- ============================================================
       ADRs
  ============================================================ -->
  <section class="transp-section transp-section--alt" id="adrs" aria-labelledby="adrs-heading">
    <div class="transp-container">
      <p class="transp-eyebrow-sm">Decisões de arquitetura</p>
      <h2 class="transp-h2" id="adrs-heading">ADRs — Architecture Decision Records</h2>
      <p class="transp-section-lead">
        Cada decisão relevante é registrada com contexto, alternativas consideradas e
        consequências. ADR não é burocracia — é memória institucional auditável.
      </p>

      <div class="transp-adr-list">
        <a href="/adr/0001-domain-kernel-emmett/" class="transp-adr-card">
          <div class="transp-adr-num">ADR-001</div>
          <div class="transp-adr-body">
            <p class="transp-adr-title">Domain Kernel — Emmett event store</p>
            <p class="transp-adr-desc">
              Adoção de Emmett como event store — spike gate PASSED em Postgres real com
              parallel writers + stale version + concurrent dispensation.
            </p>
          </div>
          <div class="transp-adr-arrow" aria-hidden="true">→</div>
        </a>

        <a href="/adr/0002-mcp-first-surface/" class="transp-adr-card">
          <div class="transp-adr-num">ADR-002</div>
          <div class="transp-adr-body">
            <p class="transp-adr-title">Surface pivot — MCP-First</p>
            <p class="transp-adr-desc">
              Admin Next.js descartado. Toda operação via MCP server + MCP Apps + Open WebUI.
              Cancelou ~3-4 semanas de trabalho; mesma cobertura operacional, menos complexidade.
            </p>
          </div>
          <div class="transp-adr-arrow" aria-hidden="true">→</div>
        </a>

        <a href="/adr/0003-stack-pivot-nats-surreal-dbos/" class="transp-adr-card">
          <div class="transp-adr-num">ADR-003</div>
          <div class="transp-adr-body">
            <p class="transp-adr-title">Stack pivot — NATS + SurrealDB + DBOS</p>
            <p class="transp-adr-desc">
              Decisão sobre infraestrutura de mensageria, banco de dados e orquestração
              de workflows duráveis.
            </p>
          </div>
          <div class="transp-adr-arrow" aria-hidden="true">→</div>
        </a>

        <a href="/adr/0004-simulation-vps/" class="transp-adr-card">
          <div class="transp-adr-num">ADR-004</div>
          <div class="transp-adr-body">
            <p class="transp-adr-title">Simulação VPS — validação de deploy</p>
            <p class="transp-adr-desc">
              Estratégia de validação de deploy em VPS antes do piloto real —
              Coolify + Traefik + wildcard TLS.
            </p>
          </div>
          <div class="transp-adr-arrow" aria-hidden="true">→</div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       VISÃO OSS
  ============================================================ -->
  <section class="transp-section" id="oss" aria-labelledby="oss-heading">
    <div class="transp-container">
      <p class="transp-eyebrow-sm">Visão OSS</p>
      <h2 class="transp-h2" id="oss-heading">Por que código aberto?</h2>

      <div class="transp-oss-grid">
        <div class="transp-oss-body">
          <p class="transp-oss-text">
            O canna-br é licenciado sob AGPL-3.0. Isso significa que qualquer modificação
            — inclusive se alguém usar o código para construir um SaaS concorrente — precisa
            ser devolvida como código aberto.
          </p>
          <p class="transp-oss-text">
            A escolha não é altruísmo; é estratégia. Associações de cannabis operam em
            território regulatório complexo e precisam de software que possa ser auditado,
            modificado e entendido pela própria diretoria jurídica — não apenas pela empresa
            que fornece o produto.
          </p>
          <p class="transp-oss-text">
            Self-host é sempre uma opção. Managed hosting é o modelo sustentável para quem
            não quer gerenciar infraestrutura — mas o código nunca fica trancado.
          </p>
        </div>

        <div class="transp-oss-aside">
          <div class="transp-oss-item">
            <span class="transp-oss-label">Licença</span>
            <span class="transp-oss-value">AGPL-3.0</span>
          </div>
          <div class="transp-oss-item">
            <span class="transp-oss-label">Repositório</span>
            <a href="https://github.com/biliboss/canna-br" class="transp-oss-link" target="_blank" rel="noopener noreferrer">
              github.com/biliboss/canna-br
            </a>
          </div>
          <div class="transp-oss-item">
            <span class="transp-oss-label">Fork permitido?</span>
            <span class="transp-oss-value">Sim — mantenha a licença AGPL</span>
          </div>
          <div class="transp-oss-item">
            <span class="transp-oss-label">Self-host</span>
            <span class="transp-oss-value">Sempre disponível</span>
          </div>
          <div class="transp-oss-item">
            <span class="transp-oss-label">Lock-in</span>
            <span class="transp-oss-value">Zero — dados são seus</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       STATUS DO SISTEMA (honesto: pré-piloto)
  ============================================================ -->
  <section class="transp-section transp-section--alt" id="status" aria-labelledby="status-heading">
    <div class="transp-container">
      <p class="transp-eyebrow-sm">Status atual</p>
      <h2 class="transp-h2" id="status-heading">Estado do sistema — pré-piloto</h2>

      <div class="transp-status-grid">
        <div class="transp-status-card transp-status-card--ok">
          <div class="transp-status-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <p class="transp-status-title">Domain kernel</p>
          <p class="transp-status-desc">Eventos, invariantes e trilha de auditoria — 154/154 testes verdes</p>
        </div>

        <div class="transp-status-card transp-status-card--ok">
          <div class="transp-status-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <p class="transp-status-title">MCP server + apps</p>
          <p class="transp-status-desc">3 apps inline validados — smoke OWUI v0.9.6 end-to-end</p>
        </div>

        <div class="transp-status-card transp-status-card--ok">
          <div class="transp-status-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <p class="transp-status-title">Deploy VPS</p>
          <p class="transp-status-desc">canna-br.fonsecagabriel.com.br — Coolify + Traefik, TLS ativo</p>
        </div>

        <div class="transp-status-card transp-status-card--wait">
          <div class="transp-status-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <p class="transp-status-title">Piloto com associação real</p>
          <p class="transp-status-desc">Vagas abertas — critérios e onboarding em <a href="/piloto/" class="transp-status-link">Piloto</a></p>
        </div>

        <div class="transp-status-card transp-status-card--wait">
          <div class="transp-status-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <p class="transp-status-title">SNGPC produção</p>
          <p class="transp-status-desc">Mock XML pronto — aguardando ANVISA publicar schema XSD específico para associações</p>
        </div>

        <div class="transp-status-card transp-status-card--plan">
          <div class="transp-status-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <p class="transp-status-title">RBAC e autenticação TOTP</p>
          <p class="transp-status-desc">Planejado para v0.3 (set/2026) — requisito para associações reais</p>
        </div>
      </div>

      <div class="transp-honesty-note">
        <p class="transp-honesty-text">
          <strong>Honestidade acima de marketing:</strong> o canna-br está em estágio
          pré-piloto. O código existe, os testes passam, o deploy está no ar — mas nenhuma
          associação usa em produção ainda. Os indicadores acima refletem isso com precisão.
        </p>
        <a href="/piloto/" class="transp-btn-primary">Entrar como piloto →</a>
      </div>
    </div>
  </section>

</MarketingLayout>

<style>
  /* ================================================================
     TRANSPARÊNCIA — dark slate + emerald tokens, espelha index.astro
  ================================================================ */

  /* ── shared ── */
  .transp-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .transp-eyebrow {
    font-size: 0.72rem;
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #10b981;
    margin: 0 0 1rem;
  }
  .transp-eyebrow-sm {
    font-size: 0.7rem;
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #10b981;
    margin: 0 0 0.6rem;
  }

  .transp-h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin: 0 0 1.25rem;
  }
  .hide-mobile { display: inline; }
  @media (max-width: 480px) { .hide-mobile { display: none; } }

  .transp-h2 {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.25;
    letter-spacing: -0.025em;
    margin: 0 0 0.75rem;
  }

  .transp-lead {
    color: #94a3b8;
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 680px;
    margin: 0 0 2rem;
  }

  .transp-section-lead {
    color: #94a3b8;
    font-size: 0.95rem;
    line-height: 1.65;
    max-width: 640px;
    margin: 0 0 2rem;
  }

  /* ── widget host wrapper ── */
  .transp-widget-wrap {
    width: 100%;
    max-width: 100%;
    overflow-x: auto;
  }

  /* ── sections ── */
  .transp-hero {
    background: linear-gradient(180deg, oklch(0.12 0.04 162 / 0.9) 0%, #020617 100%);
    padding: 6rem 0 4rem;
    border-bottom: 1px solid oklch(0.28 0.04 162 / 0.25);
  }

  .transp-section {
    padding: 5rem 0;
  }

  .transp-section--alt {
    padding: 5rem 0;
    background: oklch(0.09 0.01 250 / 0.6);
    border-top: 1px solid oklch(0.22 0.02 250 / 0.5);
    border-bottom: 1px solid oklch(0.22 0.02 250 / 0.5);
  }

  /* ── hero badges ── */
  .transp-hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .transp-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-weight: 600;
    letter-spacing: 0.03em;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    border: 1px solid transparent;
  }
  .transp-badge--ok   { color: oklch(0.84 0.14 162); background: oklch(0.5 0.12 162 / 0.12); border-color: oklch(0.5 0.12 162 / 0.4); }
  .transp-badge--info { color: oklch(0.82 0.12 75);  background: oklch(0.55 0.12 75 / 0.12);  border-color: oklch(0.55 0.12 75 / 0.4); }
  .transp-badge--plan { color: oklch(0.72 0.02 250); background: oklch(0.45 0.02 250 / 0.18); border-color: oklch(0.5 0.02 250 / 0.5); }

  /* ── por que transparência ── */
  .transp-why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
    gap: 1.25rem;
  }
  .transp-why-card {
    background: oklch(0.15 0.015 250);
    border: 1px solid oklch(0.28 0.04 162 / 0.4);
    border-radius: 16px;
    padding: 1.5rem;
  }
  .transp-why-icon {
    width: 2.25rem;
    height: 2.25rem;
    background: oklch(0.22 0.06 162 / 0.5);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #10b981;
    margin-bottom: 1rem;
  }
  .transp-why-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
  }
  .transp-why-text {
    font-size: 0.875rem;
    color: #94a3b8;
    line-height: 1.6;
    margin: 0;
  }

  /* ── roadmap grid ── */
  .transp-roadmap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .transp-rm-card {
    border-radius: 16px;
    padding: 1.25rem;
    border: 1px solid transparent;
  }
  .transp-rm-card--done   { background: oklch(0.16 0.02 162 / 0.4); border-color: oklch(0.45 0.12 162 / 0.5); }
  .transp-rm-card--next   { background: oklch(0.15 0.015 250);       border-color: oklch(0.55 0.12 162 / 0.6); }
  .transp-rm-card--future { background: oklch(0.14 0.01 250);        border-color: oklch(0.35 0.02 250 / 0.5); }

  .transp-rm-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }
  .transp-rm-badge {
    font-size: 0.63rem;
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
