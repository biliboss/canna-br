---
import IntroVideoModal from '../components/IntroVideoModal.astro';
import ApplyVideoModal from '../components/ApplyVideoModal.astro';
import Lightbox from '../components/Lightbox.astro';
import InvitationCard from '../components/InvitationCard.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
import '../styles/global.css';

const title = "canna-br — Sistema OSS para Associações de Cannabis";
const description = "Plataforma OSS de gestão para associações de cannabis medicinal no Brasil. LGPD-by-design. SNGPC em desenvolvimento (mock atual). Arquitetura preparada para RDC 1.014/2026.";
---

<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://canna-br.fonsecagabriel.com.br/" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href="https://canna-br.fonsecagabriel.com.br/" />
  <link rel="alternate" hreflang="pt-BR" href="https://canna-br.fonsecagabriel.com.br/" />
  <link rel="alternate" hreflang="en" href="https://canna-br.fonsecagabriel.com.br/en/" />
  <link rel="alternate" hreflang="es" href="https://canna-br.fonsecagabriel.com.br/es/" />
  <link rel="alternate" hreflang="x-default" href="https://canna-br.fonsecagabriel.com.br/" />
  <style>
    :root { color-scheme: dark; }
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0;
      background: #020617;
      color: #e2e8f0;
      font-family: -apple-system, BlinkMacSystemFont, 'Inter', 'Segoe UI', sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    /* ---- Floating pill nav ---- */
    .floating-nav {
      position: fixed;
      top: 1.25rem;
      left: 50%;
      transform: translateX(-50%);
      z-index: 50;
      backdrop-filter: blur(12px) saturate(180%);
      background: rgba(15, 23, 42, 0.72);
      border: 1px solid rgba(16, 185, 129, 0.22);
      border-radius: 999px;
      padding: 0.5rem 0.75rem 0.5rem 1.25rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.875rem;
      white-space: nowrap;
    }
    .floating-nav a { color: #94a3b8; text-decoration: none; transition: color 0.2s; }
    .floating-nav a:hover { color: #6ee7b7; }
    .floating-nav .brand { color: white; font-weight: 700; letter-spacing: -0.03em; font-size: 1rem; }
    .floating-nav .docs-cta {
      background: rgba(16, 185, 129, 0.15);
      border: 1px solid rgba(16, 185, 129, 0.4);
      color: #6ee7b7;
      padding: 0.375rem 1rem;
      border-radius: 999px;
      font-weight: 600;
    }
    .floating-nav .docs-cta:hover { background: rgba(16, 185, 129, 0.28); color: white; }
    @media (max-width: 640px) {
      .floating-nav .link-secondary { display: none; }
      .floating-nav .link-tertiary { display: none; }
    }
    @media (max-width: 860px) {
      .floating-nav .link-tertiary { display: none; }
    }
  </style>
</head>
<body>

  <!-- Floating pill nav -->
  <nav class="floating-nav" aria-label="Navegação principal">
    <a href="/" class="brand">canna-br</a>
    <a href="/build/big-picture/" class="link-secondary">Big Picture</a>
    <a href="/idea/regulation/" class="link-secondary">Regulação</a>
    <a href="/open/seed-associations/" class="link-secondary">Piloto</a>
    <a href="/#circulo-convites" class="link-secondary">Convites</a>
    <a href="/trust/" class="link-tertiary">Confiança</a>
    <a href="/sobre-o-mercado/" class="link-tertiary">Mercado</a>
    <a href="/build/stack/" class="docs-cta">Docs →</a>
    <LangSwitcher />
  </nav>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-gradient-to-b from-emerald-950 to-slate-950 text-white py-36 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-tight">
        Conformidade RDC 1.014 com rastreabilidade imutável — e código aberto que sua diretoria pode auditar.
      </h1>
      <p class="text-xl md:text-2xl text-emerald-100/80 mt-8 max-w-2xl mx-auto">
        Spine de compliance operacional para associações de cannabis medicinal no Brasil — dispensação, rastreabilidade e audit trail. LGPD-by-design. SNGPC em desenvolvimento (mock atual; schema XSD ANVISA pendente jun/2026). Cultivo e financeiro no roadmap v1.0 (2028). Self-hosted ou gerenciado — seus dados ficam com você.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-12 justify-center items-center">
        <button
          type="button"
          id="open-apply-modal"
          class="inline-flex items-center justify-center gap-2 px-10 py-5 rounded-full bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-extrabold text-xl transition shadow-2xl shadow-emerald-500/40 focus-visible:ring-4 ring-emerald-400"
          aria-label="Solicitar vaga como associação piloto"
        >
          Aplicar como piloto →
        </button>
        <a
          href="https://github.com/biliboss/canna-br"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-6 py-3 rounded-full border border-emerald-400/40 text-emerald-300/80 hover:bg-emerald-400/10 font-medium text-base transition focus-visible:ring-2 ring-emerald-400"
          aria-label="Ver código-fonte canna-br (repo em organização v0.3)"
        >
          Explorar o Código
        </a>
        <p class="text-xs font-mono text-emerald-200/40 mt-3">Repo dedicado em organização — v0.3 (jul 2026). Hoje: vault de desenvolvimento.</p>
      </div>

      <div class="mt-4 text-center">
        <a
          href="/about/"
          class="font-mono uppercase tracking-widest text-xs text-emerald-200/40 hover:text-emerald-200/70 transition"
          aria-label="Saiba quem está por trás do projeto"
        >
          Quem está por trás
        </a>
      </div>

      <div class="text-sm text-emerald-200/60 mt-6 flex flex-wrap gap-x-4 gap-y-1 justify-center">
        <span>v0.2.1.2 LIVE</span>
        <span>·</span>
        <span>154/154 testes</span>
        <span>·</span>
        <a href="https://canna-br.fonsecagabriel.com.br" target="_blank" rel="noopener" class="underline underline-offset-2 hover:text-emerald-200 transition">canna-br.fonsecagabriel.com.br</a>
      </div>

      <div class="mt-8 flex justify-center">
        <IntroVideoModal videoSrc="https://canna-br-apply.gabrielfonseca.workers.dev/api/intro" />
      </div>
    </div>
  </section>

  <!-- ============================================================
       URGENCIA & GAP
       ============================================================ -->
  <section class="bg-red-950/30 border-l-4 border-red-500 py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <p class="text-xs font-mono font-bold text-red-400 uppercase tracking-widest mb-4">Alerta regulatório</p>
      <h2 class="text-2xl md:text-3xl font-bold text-red-200 mb-6 leading-snug">
        Em 4 de agosto de 2026 a janela fecha. Associações sem sistema conforme aumentam sua exposição regulatória.
      </h2>
      <p class="text-red-100/70 text-lg mb-8 leading-relaxed">
        A RDC 1.014/2026 é o primeiro regime administrativo formal para associações de pacientes no Brasil. Substituiu o Habeas Corpus judicial (STJ Tema 16 IAC, 2023). A partir de agosto, fiscalização direta da ANVISA exige audit trail imutável, SNGPC integrado, RBAC com segregação de funções e rastreabilidade seed-to-dispensação.
      </p>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-red-950/40 border border-red-800/50 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-2">
            <span aria-hidden="true" class="text-red-300 text-xl">⚖️</span>
            <p class="font-bold text-red-200">Responsabilidade pessoal LGPD</p>
          </div>
          <p class="text-red-100/60 text-sm mb-3">Dados de saúde em SaaS fechado sem DPA e DPO designado expõe diretores a responsabilidade pessoal (LGPD Art. 5 II). Mitigação: self-host + DPO + contratos.</p>
          <a href="/build/compliance/" class="text-red-300/80 hover:text-red-200 text-xs font-mono underline">ver detalhes legais →</a>
        </div>
        <div class="bg-red-950/40 border border-red-800/50 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-2">
            <span aria-hidden="true" class="text-red-300 text-xl">📋</span>
            <p class="font-bold text-red-200">Multa ANVISA + Perda do HC</p>
          </div>
          <p class="text-red-100/60 text-sm mb-3">Ausência de audit trail e SNGPC conforme resulta em auto de infração, suspensão e cassação da autorização.</p>
          <a href="/idea/regulation/" class="text-red-300/80 hover:text-red-200 text-xs font-mono underline">ver detalhes legais →</a>
        </div>
        <div class="bg-red-950/40 border border-red-800/50 rounded-xl p-5">
          <div class="flex items-center gap-2 mb-2">
            <span aria-hidden="true" class="text-red-300 text-xl">🔐</span>
            <p class="font-bold text-red-200">Exposição regulatória LGPD</p>
          </div>
          <p class="text-red-100/60 text-sm mb-3">Software sem crypto-deletion (Art. 18 IV) impede exclusão efetiva de dados sensíveis de saúde — obrigação legal irrenunciável.</p>
          <a href="/build/compliance/" class="text-red-300/80 hover:text-red-200 text-xs font-mono underline">ver detalhes legais →</a>
        </div>
      </div>

      <p class="text-red-200/50 text-sm mt-8">
        <strong class="text-red-300">Gap confirmado:</strong> nenhuma solução cobre LGPD + SNGPC + self-hosted + código auditável simultaneamente. openthc/pos, cannlytics, XURU, BudApp — nenhum.
      </p>
    </div>
  </section>

  <!-- ============================================================
       3 PILARES
       ============================================================ -->
  <section class="py-24 px-6" style="background: rgba(15,23,42,0.8)">
    <div class="max-w-4xl mx-auto">
      <p class="text-xs font-mono font-bold text-emerald-400 uppercase tracking-widest text-center mb-4">Por que canna-br</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-12 leading-tight">
        Três pilares que não existem juntos em nenhum outro sistema
      </h2>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-slate-900/60 border border-emerald-900/40 rounded-2xl p-8 hover:border-emerald-500/50 transition">
          <div class="w-10 h-10 rounded-xl bg-emerald-900/60 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">LGPD-by-design</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-4">
            Controle técnico dos dados de saúde (LGPD-by-design) — mitiga risco técnico (eliminação completa requer mais que software: DPO designado, RT farmacêutica, RIPD documentado, contratos). Envelope criptográfico AES-256-GCM por membro. Crypto-deletion garantida (Art. 18 IV LGPD). Self-host opcional. Cada associação dona dos próprios dados.
          </p>
          <p class="text-emerald-400/70 text-xs font-mono">Criptografia individual · Self-hosted · LGPD Art. 18 IV</p>
        </div>

        <div class="bg-slate-900/60 border border-emerald-900/40 rounded-2xl p-8 hover:border-emerald-500/50 transition">
          <div class="w-10 h-10 rounded-xl bg-emerald-900/60 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">SNGPC em desenvolvimento</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-4">
            Arquitetura preparada para RDC 1.014 (homologação SNGPC pendente). XML conforme portaria implementado em mock — schema XSD específico para associações ainda não publicado pela ANVISA (jun/2026). Retry durável com BullMQ. Audit log imutável via event sourcing. Rastreabilidade seed-to-dispensação completa.
          </p>
          <p class="text-amber-400/70 text-xs font-mono">SNGPC mock — pronto para integração quando ANVISA publicar XSD</p>
          <p class="text-emerald-400/70 text-xs font-mono">RDC 1.014 · SNGPC mock · 7 KPIs ANVISA</p>
        </div>

        <div class="bg-slate-900/60 border border-emerald-900/40 rounded-2xl p-8 hover:border-emerald-500/50 transition">
          <div class="w-10 h-10 rounded-xl bg-emerald-900/60 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white mb-3">OSS auditável</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-4">
            Rastreabilidade imutável e à prova de auditoria. AGPL-3.0 — código aberto, sem lock-in, fork permitido. Qualquer advogado da associação pode revisar cada linha que processa dados dos membros. Ledger 100% verificável.
          </p>
          <p class="text-emerald-400/70 text-xs font-mono">AGPL-3.0 · Event Sourcing · Audit trail</p>
        </div>
      </div>

      <div class="mt-10 bg-slate-900/40 border border-slate-800 rounded-xl p-6 text-center">
        <p class="text-emerald-300/80 text-sm leading-relaxed">
          <strong class="text-emerald-300">Pronto para IA e automações governamentais</strong> — toda operação de negócio exposta como ferramenta MCP antes de qualquer UI. Integrável com agentes, automações externas e pipelines ANVISA sem scraping ou workarounds.
        </p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       COMO FUNCIONA EM 4 PASSOS
       ============================================================ -->
  <section class="py-24 px-6" style="background: rgba(15,23,42,0.6)">
    <div class="max-w-5xl mx-auto">
      <p class="text-xs font-mono font-bold text-emerald-400 uppercase tracking-widest text-center mb-4">Como funciona</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4 leading-tight">
        Do diagnóstico à auditoria em 4 passos.
      </h2>
      <p class="text-slate-400 text-center mb-12 max-w-2xl mx-auto">
        Pensado pra equipe pequena: você não precisa de TI dedicada. Operação acontece no chat.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 mb-12">
        <div class="bg-slate-900/60 border border-emerald-900/40 rounded-2xl p-6 hover:border-emerald-500/50 transition relative">
          <div class="absolute -top-3 -left-3 w-10 h-10 rounded-full bg-emerald-500 text-slate-950 font-extrabold text-lg flex items-center justify-center shadow-lg shadow-emerald-500/40">01</div>
          <h3 class="text-lg font-bold text-white mb-3 mt-2">Diagnóstico</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-3">Onboarding call (1h). Identificamos sua estrutura jurídica atual (HC × RDC), fluxo de dispensação, integração SNGPC ou ausência.</p>
          <p class="text-emerald-300/70 text-xs font-mono">Saída: dossier do estado atual + roadmap de adesão RDC 1.014.</p>
        </div>
        <div class="bg-slate-900/60 border border-emerald-900/40 rounded-2xl p-6 hover:border-emerald-500/50 transition relative">
          <div class="absolute -top-3 -left-3 w-10 h-10 rounded-full bg-emerald-500 text-slate-950 font-extrabold text-lg flex items-center justify-center shadow-lg shadow-emerald-500/40">02</div>
          <h3 class="text-lg font-bold text-white mb-3 mt-2">Configuração segura</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-3">Provisionamos sua instância (self-host ou canna-br.fonsecagabriel.com.br). Importamos cadastro de membros, lotes, prescrições. Crypto keys geradas localmente.</p>
          <p class="text-emerald-300/70 text-xs font-mono">Saída: ambiente isolado + dados migrados + RT treinado.</p>
        </div>
        <div class="bg-slate-900/60 border border-emerald-900/40 rounded-2xl p-6 hover:border-emerald-500/50 transition relative">
          <div class="absolute -top-3 -left-3 w-10 h-10 rounded-full bg-emerald-500 text-slate-950 font-extrabold text-lg flex items-center justify-center shadow-lg shadow-emerald-500/40">03</div>
          <h3 class="text-lg font-bold text-white mb-3 mt-2">Operação no chat</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-3">RT dispensa via Open WebUI: "Registrar dispensação 5g paciente X lote Y". Sistema valida cota, deduz inventário, gera SNGPC, registra evento imutável.</p>
          <p class="text-emerald-300/70 text-xs font-mono">Saída: dispensação sem planilhas paralelas, SNGPC zero-friction.</p>
        </div>
        <div class="bg-slate-900/60 border border-emerald-900/40 rounded-2xl p-6 hover:border-emerald-500/50 transition relative">
          <div class="absolute -top-3 -left-3 w-10 h-10 rounded-full bg-emerald-500 text-slate-950 font-extrabold text-lg flex items-center justify-center shadow-lg shadow-emerald-500/40">04</div>
          <h3 class="text-lg font-bold text-white mb-3 mt-2">Auditoria automática</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-3">Fiscal ANVISA chega? Diretoria abre painel, gera relatório trimestral assinado, exporta trilha imutável seed-to-dispensação. Sem caça ao tesouro em planilhas.</p>
          <p class="text-emerald-300/70 text-xs font-mono">Saída: dossier auditável em minutos, não dias.</p>
        </div>
      </div>

      <div class="bg-slate-950/70 border border-emerald-700/30 rounded-2xl p-8 max-w-3xl mx-auto text-center">
        <div class="flex items-center justify-center gap-3 mb-4">
          <p class="text-xs font-mono font-bold text-emerald-400 uppercase tracking-widest">Demo gravada</p>
        </div>
        <p class="text-slate-300 text-base font-semibold mb-3">Walkthrough RT + auditor + relatório RDC — gravação prevista para Q3 2026.</p>
        <p class="text-slate-400 text-sm mb-6 leading-relaxed">
          Walkthrough RT dispensando + auditor rastreando lote + diretoria gerando relatório RDC. Será gravado na instância da primeira associação piloto após onboarding.
        </p>
        <span class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-slate-800/60 border border-emerald-900/40 text-emerald-300/60 text-sm font-mono" aria-label="Demo gravada prevista para Q3 2026">
          <span>Demo gravada · Q3 2026</span>
        </span>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRODUTO NA PRATICA (screenshots OWUI + MCP Apps)
       ============================================================ -->
  <section id="produto-na-pratica" class="py-24 px-6" style="background: rgba(2,6,23,0.92)">
    <div class="max-w-6xl mx-auto">
      <p class="text-xs font-mono font-bold text-emerald-400 uppercase tracking-widest text-center mb-4">Produto na prática</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white text-center mb-4 leading-tight">
        Não é deck. Aqui está o sistema rodando em smoke validation.
      </h2>
      <p class="text-slate-400 text-center mb-12 max-w-3xl mx-auto">
        Capturas reais do <strong class="text-emerald-300">Open WebUI v0.9.6 + MCP server canna-br</strong> em 2026-06-08. Não há admin Next.js separada — a operação acontece dentro do chat com MCP Apps inline. O que você vê abaixo é o que sua equipe usa.
      </p>

      <!-- Gallery hint: click any card thumbnail to open fullscreen (PhotoSwipe v5) -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

        <!-- Card 1 -->
        <div class="screenshot-card">
          <div class="screenshot-thumb-wrap">
            <Lightbox
              src="/screenshots/owui/06-member-quota-rendered.png"
              alt="MemberQuotaCardApp renderizado dentro do chat — quota mensal, dispensações usadas, histórico"
              width={1280}
              height={800}
            />
            <span class="screenshot-zoom-hint" aria-hidden="true">clique para ampliar</span>
          </div>
          <div class="screenshot-meta">
            <p class="screenshot-eyebrow">MCP App · Membro</p>
            <p class="screenshot-title">Quota e histórico do membro</p>
            <p class="screenshot-desc">Dispensador pergunta "qual a quota do João?" — app inline mostra prescrição vigente, quota mensal, dispensações usadas. Zero tela CRUD.</p>
          </div>
        </div>

        <!-- Card 2 -->
        <div class="screenshot-card">
          <div class="screenshot-thumb-wrap">
            <Lightbox
              src="/screenshots/owui/07-dispensation-form.png"
              alt="DispensationFormApp — formulário inline com seleção de lote, quantidade, dispensador, gate de aprovação"
              width={1280}
              height={800}
            />
            <span class="screenshot-zoom-hint" aria-hidden="true">clique para ampliar</span>
          </div>
          <div class="screenshot-meta">
            <p class="screenshot-eyebrow">MCP App · Dispensação</p>
            <p class="screenshot-title">Registro de dispensação inline</p>
            <p class="screenshot-desc">Formulário renderizado no chat com gate de aprovação. Commit gera evento <code class="code-inline">DispensationRecorded</code> + <code class="code-inline">LotQuantityDeducted</code> atômicos no ledger.</p>
          </div>
        </div>

        <!-- Card 3 -->
        <div class="screenshot-card">
          <div class="screenshot-thumb-wrap">
            <Lightbox
              src="/screenshots/owui/08-traceability-timeline.png"
              alt="TraceabilityTimelineApp — linha do tempo seed-to-dispensação com hashes de eventos"
              width={1280}
              height={800}
            />
            <span class="screenshot-zoom-hint" aria-hidden="true">clique para ampliar</span>
