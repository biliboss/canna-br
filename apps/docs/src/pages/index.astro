            ctaSecondaryLabel="Ler antes — o que isso significa"
            ctaSecondaryHref="/open/perguntas/"
            signedBy="Gabriel"
          />
        </div>

        <div role="listitem" class="snap-card">
          <InvitationCard
            name="Eduardo Yoshimura"
            photoUrl="/people/eduardo.png"
            role="Guardião de Segurança"
            roleSubtitle="sentinela de dados e infraestrutura"
            bio="Security specialist com passagem por Creditas, Itaú Unibanco e Módulo Security Solutions, hoje na Nodex Consulting — especializada em Cybersegurança, GRC e automação com IA. Ativista na Associação Cannábica de Jundiaí (ACM Jundiaí), onde a utilidade pública foi reconhecida pela Câmara Municipal em 2026."
            whyYou={[
              "Associações cannábicas são alvos reais de vazamento, vigilância e pressão institucional — ter um security specialist dentro do círculo é não-negociável.",
