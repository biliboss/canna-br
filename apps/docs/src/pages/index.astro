    <style>
      /* ================================================================
         CAROUSEL — pure CSS scroll-snap + progressive enhancement JS
         Pattern: scroll-snap mandatory, scrollbar hidden, arrow overlays
         Reference: Vercel /templates gallery pattern (2025-2026)
      ================================================================ */

      .convites-carousel-outer {
        position: relative;
        /* allow arrows to escape the track horizontally on wide screens */
      }

      /* ── Track ── */
      .carousel-track {
        display: grid;
        grid-auto-flow: column;
        /* Each card: min 85vw on mobile, max 760px on desktop */
        grid-auto-columns: minmax(min(85vw, 760px), 760px);
        gap: 1.5rem;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-padding-inline: max(1.5rem, calc((100vw - 760px) / 2));
        scrollbar-width: none;
        padding: 0.5rem max(1.5rem, calc((100vw - 760px) / 2)) 2rem;
        outline: none;
        /* smooth scroll driven via JS — CSS fallback is swipe */
      }

      .carousel-track::-webkit-scrollbar { display: none; }

      /* ── Snap cards ── */
      .snap-card {
        scroll-snap-align: center;
        /* prevent card from collapsing when grid-auto-columns hits min */
        min-width: 0;
      }

      /* On wide screens (≥1400px) show 2 cards at once if they fit */
      @media (min-width: 1400px) {
        .carousel-track {
          grid-auto-columns: minmax(min(48%, 760px), 760px);
          scroll-padding-inline: max(1.5rem, calc((100vw - 1554px) / 2));
          padding: 0.5rem max(1.5rem, calc((100vw - 1554px) / 2)) 2rem;
        }
        .snap-card {
          scroll-snap-align: start;
        }
      }

      /* Mobile: full-bleed feel */
      @media (max-width: 639px) {
        .carousel-track {
          grid-auto-columns: 90vw;
          gap: 1rem;
          padding: 0.5rem 1rem 1.5rem;
          scroll-padding-inline: 1rem;
        }
      }

      /* ── Arrow buttons ── */
      .carousel-arrow {
        display: none; /* hidden on mobile — swipe only */
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 20;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        border: 1px solid oklch(0.45 0.10 162 / 0.45);
        background: oklch(0.12 0.015 250 / 0.90);
        color: oklch(0.84 0.13 162);
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
        transition: background 0.15s ease-out, border-color 0.15s ease-out, opacity 0.15s;
      }

      @media (min-width: 768px) {
        .carousel-arrow {
          display: flex;
        }
      }

      .carousel-prev { left: 0.5rem; }
      .carousel-next { right: 0.5rem; }

      .carousel-arrow:hover {
        background: oklch(0.18 0.02 250 / 0.95);
        border-color: oklch(0.72 0.17 162 / 0.70);
      }

      .carousel-arrow:focus-visible {
        outline: 2px solid oklch(0.72 0.17 162);
        outline-offset: 2px;
      }

      .carousel-arrow:disabled,
      .carousel-arrow[disabled] {
        opacity: 0.25;
        cursor: default;
        pointer-events: none;
      }

      /* ── Dots ── */
      .carousel-dots {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        margin-top: 1.25rem;
        padding: 0 1rem;
      }

      .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        border: 1px solid oklch(0.45 0.10 162 / 0.6);
        background: transparent;
        cursor: pointer;
        padding: 0;
        transition: background 0.2s ease-out, transform 0.2s ease-out, border-color 0.2s ease-out;
        /* Expand touch target via box-shadow trick — visual stays 8px */
        box-shadow: 0 0 0 8px transparent;
      }

      .dot:hover {
        border-color: oklch(0.72 0.17 162 / 0.8);
        background: oklch(0.72 0.17 162 / 0.3);
      }

      .dot-active,
      .dot[aria-selected="true"] {
        background: oklch(0.72 0.17 162);
        border-color: oklch(0.72 0.17 162);
        transform: scale(1.3);
      }

      .dot:focus-visible {
        outline: 2px solid oklch(0.72 0.17 162);
        outline-offset: 3px;
      }

      /* ── Reduced motion ── */
      @media (prefers-reduced-motion: reduce) {
        .carousel-track {
          scroll-behavior: auto !important;
        }
        .dot,
        .carousel-arrow {
          transition-duration: 0.01ms !important;
        }
      }
    </style>

    <script is:inline>
    (function () {
      var track    = document.getElementById('convites-track');
      var dotsWrap = document.getElementById('convites-dots');
      var prevBtn  = document.querySelector('.carousel-prev');
      var nextBtn  = document.querySelector('.carousel-next');
      if (!track || !dotsWrap) return;

      var dots  = Array.from(dotsWrap.querySelectorAll('.dot'));
      var cards = Array.from(track.querySelectorAll('.snap-card'));
      var total = cards.length;

      /* ── card width (including gap) ── */
      function cardStep() {
        if (cards.length < 2) return track.scrollWidth;
        var r0 = cards[0].getBoundingClientRect();
        var r1 = cards[1].getBoundingClientRect();
        return r1.left - r0.left;
      }

      /* ── scroll to card index ── */
      function scrollTo(idx) {
        var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        track.scrollBy({
          left: (idx - activeIndex()) * cardStep(),
          behavior: reduced ? 'auto' : 'smooth',
        });
      }

      /* ── detect which card is most visible ── */
      function activeIndex() {
        var mid = track.getBoundingClientRect().left + track.getBoundingClientRect().width / 2;
        var best = 0, bestDist = Infinity;
        cards.forEach(function (c, i) {
          var cr = c.getBoundingClientRect();
          var center = cr.left + cr.width / 2;
          var dist = Math.abs(center - mid);
          if (dist < bestDist) { bestDist = dist; best = i; }
        });
        return best;
      }

      /* ── sync dots + arrows ── */
      function syncUI(idx) {
        dots.forEach(function (d, i) {
          var active = i === idx;
          d.classList.toggle('dot-active', active);
          d.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        if (prevBtn) prevBtn.disabled = idx === 0;
        if (nextBtn) nextBtn.disabled = idx === total - 1;
      }

      /* ── IntersectionObserver — sync on scroll ── */
      var obs = new IntersectionObserver(function () {
        syncUI(activeIndex());
      }, { root: track, threshold: 0.5 });
      cards.forEach(function (c) { obs.observe(c); });

      /* ── Arrow clicks ── */
      [prevBtn, nextBtn].forEach(function (btn) {
        if (!btn) return;
        btn.addEventListener('click', function () {
          var dir = parseInt(btn.getAttribute('data-dir'), 10);
          scrollTo(activeIndex() + dir);
        });
      });

      /* ── Dot clicks ── */
      dots.forEach(function (d) {
        d.addEventListener('click', function () {
          scrollTo(parseInt(d.getAttribute('data-i'), 10));
        });
      });

      /* ── Keyboard nav on track ── */
      track.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowRight') { e.preventDefault(); scrollTo(Math.min(activeIndex() + 1, total - 1)); }
        if (e.key === 'ArrowLeft')  { e.preventDefault(); scrollTo(Math.max(activeIndex() - 1, 0)); }
      });

      /* ── init ── */
      syncUI(0);
    })();
    </script>

