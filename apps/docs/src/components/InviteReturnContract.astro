  /* ================================================================
     REDUCED MOTION
  ================================================================ */
  @media (prefers-reduced-motion: reduce) {
    .irc-dot,
    .irc-copy-btn,
    .irc-tr,
    .irc-copy-toast {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
    .irc-copy-btn:hover {
      transform: none;
    }
  }
</style>

<script>
  // Copy button — clipboard.writeText with toast feedback
  // Uses data-copy-text attribute — no <, > operators risk
  (function () {
    var btn = document.querySelector('.irc-copy-btn');
    if (!btn) return;
    var toast = btn.closest('.irc-card-actions').querySelector('.irc-copy-toast');

    btn.addEventListener('click', async function () {
      var text = btn.getAttribute('data-copy-text') || '';
      try {
        await navigator.clipboard.writeText(text);
        if (toast) {
          toast.textContent = 'Convite copiado';
          toast.classList.add('irc-toast-visible');
          setTimeout(function () {
            toast.classList.remove('irc-toast-visible');
            setTimeout(function () { toast.textContent = ''; }, 250);
          }, 2200);
        }
      } catch (_) {
        // fallback: prompt
        window.prompt('Copie o texto abaixo:', text);
      }
    });
  })();
</script>
