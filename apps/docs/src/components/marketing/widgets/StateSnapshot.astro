---
/**
 * StateSnapshot — ilha "estado da rede" (v0 snapshot, não real-time).
 *
 * Contrato:
 *   - Lê `/state-snapshot.json` no cliente (fetch).
 *   - Renderiza cards: pilotos ativos, módulos entregues, releases
 *     recentes, próximos marcos + carimbo visível "atualizado em".
 *   - Skeleton enquanto carrega; mensagem honesta se falhar.
 *   - ZERO linguagem de investimento/rendimento.
 *   - Quando o sistema existir, um adaptador troca snapshot→API
 *     sem mudar esta UI.
 *
 * Design system: dark slate (#020617) + emerald accents, elevação
 * por lightness (OKLCH), sem box-shadow. Espelha index.astro.
 *
 * Acessibilidade: aria-busy no load, aria-live polite no resultado,
 * status como texto+ícone (nunca só cor), reduced-motion safe.
 */
---

<div
  class="state-snapshot"
  id="state-snapshot"
  data-src="/state-snapshot.json"
  aria-busy="true"
>
  <!-- Skeleton (substituído por JS) -->
  <div class="ss-skeleton" data-skeleton aria-hidden="true">
    {Array.from({ length: 4 }).map(() => (
      <div class="ss-card ss-card--skel">
        <div class="ss-skel-line ss-skel-line--title"></div>
        <div class="ss-skel-line"></div>
        <div class="ss-skel-line"></div>
        <div class="ss-skel-line ss-skel-line--short"></div>
      </div>
    ))}
  </div>

  <!-- Resultado vivo (preenchido por JS) -->
  <div class="ss-grid" data-grid hidden role="list" aria-live="polite"></div>

  <!-- Erro honesto (mostrado por JS se fetch falhar) -->
  <div class="ss-error" data-error hidden role="status">
    <p>Não foi possível carregar o estado da rede agora.</p>
    <p class="ss-error-sub">
      Os indicadores vivem em <a href="/transparencia/">Transparência</a> e
      <a href="/roadmap/">Roadmap</a>.
    </p>
  </div>

  <!-- Carimbo "atualizado em" -->
  <p class="ss-stamp" data-stamp hidden>
    <span class="ss-stamp-dot" aria-hidden="true"></span>
    <span data-stamp-text></span>
  </p>
</div>

<script is:inline>
  (function () {
    var root = document.getElementById('state-snapshot');
    if (!root) return;

    var grid     = root.querySelector('[data-grid]');
    var skeleton = root.querySelector('[data-skeleton]');
    var errorBox = root.querySelector('[data-error]');
    var stamp    = root.querySelector('[data-stamp]');
    var stampTxt = root.querySelector('[data-stamp-text]');
    var src      = root.getAttribute('data-src') || '/state-snapshot.json';

    function esc(s) {
      return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
        return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c];
      });
    }

    function fmtDate(iso) {
      try {
        var d = new Date(iso + 'T00:00:00');
        if (isNaN(d.getTime())) return iso;
        var m = ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];
        return d.getDate() + ' de ' + m[d.getMonth()] + ' de ' + d.getFullYear();
      } catch (e) { return iso; }
    }

    /* ── Card: pilotos ativos ── */
    function pilotCard(pilots, openPurchases) {
      var active = pilots && pilots.active != null ? pilots.active : 0;
      var note   = pilots && pilots.note ? pilots.note : 'vagas abertas';
      return ''
        + '<div class="ss-card" role="listitem">'
        +   '<p class="ss-card-eyebrow">Pilotos ativos</p>'
        +   '<p class="ss-card-caption">Associações em operação no sistema — números honestos.</p>'
        +   '<div class="ss-metric">'
        +     '<span class="ss-metric-num">' + esc(active) + '</span>'
        +     '<span class="ss-metric-unit">associações</span>'
        +   '</div>'
        +   '<p class="ss-card-note">' + esc(note) + '</p>'
        + '</div>';
    }

    /* ── Card: módulos entregues ── */
    function modulesCard(mods) {
      if (!Array.isArray(mods) || mods.length === 0) return '';
      var rows = mods.map(function (m) {
        var since = m.since ? ' <span class="ss-tag">' + esc(m.since) + '</span>' : '';
        return '<li class="ss-item"><span class="ss-dot-ok" aria-hidden="true">●</span><span class="ss-item-label">' + esc(m.name) + '</span>' + since + '</li>';
      }).join('');
      return ''
        + '<div class="ss-card" role="listitem">'
        +   '<p class="ss-card-eyebrow">Módulos entregues</p>'
        +   '<p class="ss-card-caption">O que já roda hoje, coberto por testes.</p>'
        +   '<ul class="ss-list">' + rows + '</ul>'
        + '</div>';
    }

    /* ── Card: releases recentes ── */
    function releasesCard(releases) {
      if (!Array.isArray(releases) || releases.length === 0) return '';
      var rows = releases.slice(0, 4).map(function (r) {
        var label = r.href
          ? '<a class="ss-item-label ss-item-link" href="' + esc(r.href) + '">' + esc(r.version) + '</a>'
          : '<span class="ss-item-label">' + esc(r.version) + '</span>';
        var date = r.date ? '<span class="ss-tag">' + esc(r.date) + '</span>' : '';
        var headline = r.headline ? '<p class="ss-item-sub">' + esc(r.headline) + '</p>' : '';
        return '<li class="ss-item ss-item--release">' + label + date + headline + '</li>';
      }).join('');
      return ''
        + '<div class="ss-card" role="listitem">'
        +   '<p class="ss-card-eyebrow">Releases recentes</p>'
        +   '<p class="ss-card-caption">Evolução pública, versão a versão.</p>'
        +   '<ul class="ss-list">' + rows + '</ul>'
        + '</div>';
    }

    /* ── Card: próximos marcos ── */
    function milestonesCard(milestones) {
      if (!Array.isArray(milestones) || milestones.length === 0) return '';
      var rows = milestones.map(function (ms) {
        var win = ms.window ? ' <span class="ss-tag ss-tag--plan">' + esc(ms.window) + '</span>' : '';
        var desc = ms.description ? '<p class="ss-item-sub">' + esc(ms.description) + '</p>' : '';
        return '<li class="ss-item ss-item--milestone">'
          + '<span class="ss-dot-plan" aria-hidden="true">○</span>'
          + '<span class="ss-item-label">' + esc(ms.label) + '</span>'
          + win + desc
          + '</li>';
      }).join('');
      return ''
        + '<div class="ss-card" role="listitem">'
        +   '<p class="ss-card-eyebrow">Próximos marcos</p>'
        +   '<p class="ss-card-caption">Declarados no roadmap público.</p>'
        +   '<ul class="ss-list">' + rows + '</ul>'
        + '</div>';
    }

    function render(data) {
      var cards = '';
      cards += pilotCard(data.pilots, data.openCollectivePurchases);
      cards += modulesCard(data.modulesDelivered);
      cards += releasesCard(data.recentReleases);
      cards += milestonesCard(data.nextMilestones);

      grid.innerHTML = cards;
      if (skeleton) skeleton.hidden = true;
      grid.hidden = false;
      root.setAttribute('aria-busy', 'false');

      if (data.updatedAt && stamp && stampTxt) {
        stampTxt.textContent = 'Atualizado em ' + fmtDate(data.updatedAt)
          + (data.version ? ' · ' + data.version : '')
          + ' · snapshot estático';
        stamp.hidden = false;
      }
    }

    function fail() {
      if (skeleton) skeleton.hidden = true;
      if (errorBox) errorBox.hidden = false;
      root.setAttribute('aria-busy', 'false');
    }

    fetch(src, { headers: { 'Accept': 'application/json' } })
      .then(function (r) { if (!r.ok) throw new Error(String(r.status)); return r.json(); })
      .then(render)
      .catch(fail);
  })();
</script>

<!-- is:global porque os cards são injetados via innerHTML (script):
     estilos com escopo Astro não atingem nós criados em runtime. -->
<style is:global>
  /* ================================================================
     STATE SNAPSHOT — elevação por lightness (OKLCH), sem shadow.
     Tokens espelham index.astro + screenshot-card.
  ================================================================ */
  .state-snapshot { width: 100%; }

  .ss-grid,
  .ss-skeleton {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
    gap: 1rem;
  }

  .ss-card {
    background: oklch(0.16 0.015 250);
    border: 1px solid oklch(0.28 0.04 162 / 0.45);
    border-radius: 16px;
    padding: 1.25rem 1.25rem 1.1rem;
    display: flex;
    flex-direction: column;
    transition: border-color 0.15s ease-out, background 0.15s ease-out;
  }
  .ss-card:hover {
    background: oklch(0.18 0.015 250);
    border-color: oklch(0.55 0.12 162 / 0.6);
  }

  .ss-card-eyebrow {
    color: oklch(0.78 0.15 162);
    font-size: 0.72rem;
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0 0 0.35rem;
  }
  .ss-card-caption {
    color: oklch(0.62 0.02 230);
    font-size: 0.8rem;
    line-height: 1.5;
    margin: 0 0 0.85rem;
  }
  .ss-card-note {
    color: oklch(0.72 0.17 162);
    font-size: 0.76rem;
    font-family: ui-monospace, "JetBrains Mono", monospace;
    margin: 0.5rem 0 0;
  }

  /* ── métrica grande (pilotos) ── */
  .ss-metric {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0.5rem 0;
  }
  .ss-metric-num {
    color: #fff;
    font-size: 2.25rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.04em;
    line-height: 1;
  }
  .ss-metric-unit {
    color: oklch(0.62 0.02 230);
    font-size: 0.85rem;
  }

  /* ── listas ── */
  .ss-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ss-item {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.3rem 0.45rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid oklch(0.26 0.02 250 / 0.6);
    font-size: 0.84rem;
    line-height: 1.45;
  }
  .ss-item:last-child { border-bottom: 0; padding-bottom: 0; }

  .ss-item--release,
  .ss-item--milestone {
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .ss-item-label { color: #cbd5e1; flex: 1; min-width: 0; }
  .ss-item-link {
    color: #cbd5e1;
    text-decoration: none;
    transition: color 0.15s;
  }
  .ss-item-link:hover { color: #6ee7b7; text-decoration: underline; }
  .ss-item-link:focus-visible {
    outline: 2px solid #6ee7b7;
    outline-offset: 2px;
    border-radius: 3px;
  }

  .ss-item-sub {
    width: 100%;
    color: oklch(0.58 0.02 230);
    font-size: 0.75rem;
    margin: 0.2rem 0 0 1.1rem;
    line-height: 1.4;
  }

  /* ── dots de status ── */
  .ss-dot-ok   { color: oklch(0.72 0.17 162); font-size: 0.6em; line-height: 1.8; flex-shrink: 0; }
  .ss-dot-plan { color: oklch(0.62 0.02 250); font-size: 0.6em; line-height: 1.8; flex-shrink: 0; }

  /* ── tags inline ── */
  .ss-tag {
    display: inline-flex;
    align-items: center;
    font-size: 0.65rem;
    font-family: ui-monospace, "JetBrains Mono", monospace;
    font-weight: 600;
    letter-spacing: 0.02em;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    white-space: nowrap;
    color: oklch(0.72 0.17 162);
    background: oklch(0.5 0.12 162 / 0.12);
    border: 1px solid oklch(0.5 0.12 162 / 0.38);
  }
  .ss-tag--plan {
    color: oklch(0.72 0.02 250);
    background: oklch(0.45 0.02 250 / 0.18);
    border-color: oklch(0.5 0.02 250 / 0.45);
  }

  /* ── carimbo ── */
  .ss-stamp {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    justify-content: center;
    margin: 1.5rem 0 0;
    font-size: 0.74rem;
    font-family: ui-monospace, "JetBrains Mono", monospace;
    color: oklch(0.6 0.02 230);
    letter-spacing: 0.02em;
  }
  .ss-stamp-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: oklch(0.72 0.17 162);
    box-shadow: 0 0 0 0 oklch(0.72 0.17 162 / 0.6);
    animation: ss-pulse 2.4s ease-out infinite;
    flex-shrink: 0;
  }
  @keyframes ss-pulse {
    0%   { box-shadow: 0 0 0 0 oklch(0.72 0.17 162 / 0.5); }
    70%  { box-shadow: 0 0 0 6px oklch(0.72 0.17 162 / 0); }
    100% { box-shadow: 0 0 0 0 oklch(0.72 0.17 162 / 0); }
  }

  /* ── error ── */
  .ss-error {
    text-align: center;
    padding: 2rem 1rem;
    color: #94a3b8;
    font-size: 0.9rem;
  }
  .ss-error p { margin: 0 0 0.4rem; }
  .ss-error-sub { font-size: 0.8rem; color: #8595ab; }
  .ss-error a { color: #6ee7b7; }

  /* ── skeleton ── */
  .ss-card--skel { gap: 0.6rem; min-height: 170px; }
  .ss-skel-line {
    height: 10px;
    border-radius: 4px;
    background: oklch(0.26 0.02 250);
    position: relative;
    overflow: hidden;
  }
  .ss-skel-line--title { width: 55%; height: 12px; margin-bottom: 0.4rem; }
  .ss-skel-line--short { width: 70%; }
  .ss-skel-line::after {
    content: "";
    position: absolute; inset: 0;
    transform: translateX(-100%);
    background: linear-gradient(90deg, transparent, oklch(0.4 0.03 250 / 0.5), transparent);
    animation: ss-shimmer 1.4s infinite;
  }
  @keyframes ss-shimmer { 100% { transform: translateX(100%); } }

  @media (prefers-reduced-motion: reduce) {
    .ss-card { transition-duration: 0.01ms !important; }
    .ss-stamp-dot { animation: none !important; box-shadow: none !important; }
    .ss-skel-line::after { animation: none !important; }
  }
</style>
